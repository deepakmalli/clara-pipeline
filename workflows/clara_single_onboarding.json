{
  "name": "Clara Pipeline - Single Onboarding Call",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "clara/onboarding",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "webhook-onboarding",
      "name": "Onboarding Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [240, 300],
      "webhookId": "clara-onboarding-webhook",
      "notes": "POST /webhook/clara/onboarding with { \"file_path\": \"dataset/onboarding/call1.txt\", \"account_id\": \"optional\" }"
