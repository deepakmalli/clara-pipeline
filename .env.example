# ===========================
# Clara Pipeline Configuration
# ===========================

# LLM Provider: "ollama" or "groq"
LLM_PROVIDER=ollama

# --- Ollama Settings (local) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# --- Groq Settings (free tier, optional fallback) ---
# Sign up free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# --- Task Tracker ---
# Options: "github_issues", "local_file"
# github_issues requires GITHUB_TOKEN and GITHUB_REPO
# local_file creates tasks as JSON in outputs/tasks/
TASK_TRACKER=local_file
GITHUB_TOKEN=
GITHUB_REPO=your-username/clara-pipeline

# --- Retell AI (optional) ---
# Create free account at https://www.retellai.com
# If free tier allows API access, set key here
RETELL_API_KEY=

# --- Output Settings ---
OUTPUT_DIR=outputs
DATASET_DIR=dataset
